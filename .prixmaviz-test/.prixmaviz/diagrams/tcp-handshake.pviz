  "name": "tcp-handshake",
  "engine": "plantuml",
  "kind": "passthrough",
  "dsl": "@startuml\ntitle TCP 3-Way Handshake\nparticipant Client\nparticipant Server\nClient -> Server: SYN (seq=x)\nServer -> Client: SYN-ACK (seq=y, ack=x+1)\nClient -> Server: ACK (ack=y+1)\n== Connection Established ==\nClient -> Server: Data\nServer -> Client: ACK\n@enduml\n",
