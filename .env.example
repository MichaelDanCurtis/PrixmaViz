# Host port the prixmaviz container is exposed on
HOST_PORT=5180

# Database URL — leave default for bundled Postgres, override for production
DATABASE_URL=postgres://prixmaviz:prixmaviz@postgres:5432/prixmaviz

# Kroki URL — leave default for bundled Kroki, override for external instance
KROKI_URL=http://kroki:8000

# Canonical public URL the workspace is served from (no trailing slash)
PRIXMAVIZ_PUBLIC_URL=http://localhost:5180

# Workspace TTL: how long after a workspace's last authenticated request
# before it (and its diagrams + annotations) is deleted. Workspaces
# containing any public-view diagram are exempt from TTL. Set to 0 to disable.
PRIXMAVIZ_WORKSPACE_TTL_MINUTES=60

# How often the reaper runs (minutes).
PRIXMAVIZ_REAP_INTERVAL_MINUTES=5

# Cloudflare API token for DNS-01 cert challenge (required if using Cloudflare proxy).
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Use the "Edit zone DNS" template, scoped to ailuxis.com.
# Leave empty to skip Cloudflare DNS-01 (Caddy falls back to HTTP-01 — only works without Cloudflare proxy).
CF_API_TOKEN=

# Visio (.vsdx) rendering sidecar
VSDX_RENDERER_URL=http://prixmaviz-vsdx:2003
VSDX_RENDERER_TIMEOUT_MS=10000
VSDX_MAX_BYTES=5242880
